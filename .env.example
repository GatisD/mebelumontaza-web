# EmailJS — kontaktformas integrācija
# Klients aizvieto pēc EmailJS konta izveides — instrukcijas: https://dashboard.emailjs.com/
#
# 1. Izveido kontu vietnē https://dashboard.emailjs.com/
# 2. Pievieno e-pasta servisu (Gmail / Outlook / cits) → kopē Service ID
# 3. Izveido e-pasta veidni ar mainīgajiem: {{name}}, {{phone}}, {{service}}, {{description}}
# 4. Account → API Keys → kopē Public Key
# 5. Vercel → Settings → Environment Variables → ievieto šos 3 mainīgos
#
# Ja šie env vars nav definēti, forma fallback uz mailto: ar pre-filled body.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Saņēmēja e-pasts mailto fallbackam (ja EmailJS env vars nav konfigurēti)
VITE_CONTACT_EMAIL=info@mebelumontaza.lv
